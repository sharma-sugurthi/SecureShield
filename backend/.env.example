# SecureShield backend environment
# Copy this file to .env and fill in your real keys.

GOOGLE_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=

# Optional Cloudflare AI Gateway settings
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_GATEWAY_NAME=

# Optional toggle for local cache behavior
ENABLE_CACHE=true

# --- Authentication (Supabase) ---
# Get this from Supabase Dashboard -> Project Settings -> API -> JWT Secret
SUPABASE_JWT_SECRET=

# --- Zero-Cost Emailing (Gmail SMTP) ---
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_FROM=your.email@gmail.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
